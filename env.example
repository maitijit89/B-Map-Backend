# Server Configuration
SERVER_PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=b_map
DB_PORT=5432
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRATION=72h

# External APIs
GOOGLE_PLACES_API_KEY=your_google_api_key_optional
GOOGLE_CLIENT_ID=your_google_client_id_here
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org
